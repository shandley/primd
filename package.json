{
  "name": "@shandley/primd",
  "version": "0.1.1",
  "description": "Modern, web-native primer design library \u2014 PCR, qPCR, LAMP, and assembly primers with up-to-date thermodynamics",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json && node scripts/build-cjs.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "primer design",
    "PCR",
    "LAMP",
    "bioinformatics",
    "thermodynamics",
    "molecular biology",
    "primer3"
  ],
  "author": "Scott Handley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shandley/primd.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}